# PostHog (cookieless analytics). Leave unset to disable analytics entirely.
# The project key is a public client key; it is safe to expose in the build.
# Copy to .env.local for local dev, and set as a build variable in CI.
VITE_POSTHOG_KEY=phc_your_project_key
VITE_POSTHOG_HOST=https://us.i.posthog.com
